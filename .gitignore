# Dependencies — installed via `pnpm install`, never committed
node_modules

# Build output
dist
dist-ssr
*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment variables / secrets — NEVER commit these
.env
.env.*
!.env.example

# TypeScript incremental build cache (created by `tsc -b`)
*.tsbuildinfo

# Windows "downloaded from internet" metadata (alternate data streams)
*Zone.Identifier
*:Zone.Identifier

# OS junk files
.DS_Store
Thumbs.db

# Editor / IDE folders
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
designcod.md
